<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvFilterTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Filter riwayat"
            android:textStyle="bold"
            android:textSize="18sp"
            android:paddingBottom="12dp" />

        <!-- SORT -->
        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/cbSortNewest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Semua (terbaru → terlama)" />

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/cbSortOldest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Semua (terlama → terbaru)" />

        <!-- ALGORITMA -->
        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/cbAlgoXgboost"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Algoritma XGBOOST" />

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/cbAlgoDecisionTree"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Algoritma DECISION_TREE" />

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/cbAlgoKnn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Algoritma KNN (K-Nearest Neighbor)" />

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/cbAlgoNaiveBayes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Algoritma GAUSSIAN_NB" />

        <TextView
            android:id="@+id/tvClearAllFilter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Hapus semua filter"
            android:textColor="@android:color/holo_red_dark"
            android:textStyle="bold" />
    </LinearLayout>

</ScrollView>