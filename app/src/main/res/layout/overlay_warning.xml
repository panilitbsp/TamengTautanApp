<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="16dp">

    <!-- Card utama -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:cardCornerRadius="20dp"
        app:cardElevation="6dp"
        app:cardUseCompatPadding="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- HEADER MERAH -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#F44336"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingTop="16dp"
                android:paddingEnd="20dp"
                android:paddingBottom="16dp">

                <ImageView
                    android:id="@+id/ivHeaderIcon"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginEnd="12dp"
                    android:contentDescription="@string/warning_icon"
                    android:src="@drawable/baseline_report_problem_24" />

                <TextView
                    android:id="@+id/tvHeaderTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Dangerous link found in text message!"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- ISI PUTIH -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@android:color/white"
                android:padding="20dp">

                <!-- ROW APP + WAKTU + ALGO -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:id="@+id/ivAppIcon"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_marginEnd="12dp"
                        android:contentDescription="App icon"
                        android:src="@mipmap/ic_launcher" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvAppName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Messages"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvDetectionTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="10:24 AM, Oct 15"
                            android:textColor="#777777"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Algo pill kecil di kanan -->
                    <TextView
                        android:id="@+id/tvAlgo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="10dp"
                        android:paddingTop="4dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="4dp"
                        android:background="@drawable/bg_status_pill"
                        android:text="scanned with XGBOOST"
                        android:textColor="@color/ls_text_secondary"
                        android:textSize="10sp"
                        android:textAllCaps="false" />
                </LinearLayout>

                <!-- URL TERDETEKSI -->
                <TextView
                    android:id="@+id/tvUrl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="https://contoh.com/very/suspicious/link"
                    android:textColor="#222222"
                    android:textSize="13sp"
                    android:ellipsize="end"
                    android:maxLines="2" />

                <!-- Bagian untuk link hasil unshorten (collapse/expand) -->
                <LinearLayout
                    android:id="@+id/layoutResolved"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="4dp"
                    android:visibility="gone">

                    <!-- Tombol teks: Perluas / Ciutkan -->
                    <TextView
                        android:id="@+id/tvToggleResolved"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lihat link asli"
                        android:textSize="12sp"
                        android:textColor="@color/tameng_purple"
                        android:paddingTop="2dp"
                        android:paddingBottom="2dp"
                        android:clickable="true"
                        android:focusable="true" />

                    <!-- Link hasil unshorten (ditampilkan saat diperluas) -->
                    <TextView
                        android:id="@+id/tvResolvedUrl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone"
                        android:textColor="@color/ls_text_secondary"
                        android:textSize="12sp"
                        android:autoLink="none"
                        android:ellipsize="end"
                        android:maxLines="3"
                        android:paddingTop="2dp" />
                </LinearLayout>

                <!-- RISK STATUS PILL -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Status:"
                        android:textColor="#000000"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvProb"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_score_pill"
                        android:paddingStart="10dp"
                        android:paddingTop="4dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="4dp"
                        android:text="HIGH"
                        android:textColor="#C62828"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- PEMBATAS TIPIS -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="10dp"
                    android:background="#EEEEEE" />

                <!-- REKOMENDASI TINDAKAN + CHECKBOX -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Tip 1 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="top"
                        android:paddingBottom="4dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingEnd="8dp"
                            android:text="✖"
                            android:textColor="#C62828"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvTip1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Jangan buka atau meneruskan tautan ini."
                            android:textColor="#525252"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <!-- Tip 2 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="top"
                        android:paddingBottom="4dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingEnd="8dp"
                            android:text="✖"
                            android:textColor="#C62828"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvTip2"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Hapus pesan jika tidak yakin sumbernya."
                            android:textColor="#525252"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <!-- Tip 3 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="top">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingEnd="8dp"
                            android:text="✖"
                            android:textColor="#C62828"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvTip3"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Hubungi pihak resmi lewat kanal yang terpercaya."
                            android:textColor="#525252"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <!-- Checkbox whitelist -->
                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/cbTrustDomain"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Tandai domain ini aman"
                        android:textSize="14sp"
                        android:visibility="gone" />
                </LinearLayout>

                <!-- BUTTONS -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:orientation="horizontal"
                    android:gravity="end">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDismiss"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="TUTUP"
                        android:textAllCaps="true"
                        android:textColor="@color/ls_text_secondary" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnOpenApp"
                        style="@style/Widget.MaterialComponents.Button"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:text="LIHAT DETAIL"
                        android:textAllCaps="true"
                        app:backgroundTint="@color/tameng_purple"
                        android:textColor="@android:color/white" />
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>